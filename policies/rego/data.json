{
  "gatekeeper": {
    "config": {
      "pii_exclude_fields": {
        "send_email": ["recipient"]
      },
      "denylist": {
        "send_email": {
          "field": "recipient",
          "values": ["blocked-domain.com", "spam-domain.org"]
        },
        "http_post": {
          "field": "url",
          "values": ["internal.corp", "localhost"]
        },
        "file_write": {
          "field": "path",
          "values": ["/etc/passwd", "/etc/shadow", "/root/"]
        }
      },
      "argument_bounds": {
        "http_post": {
          "timeout": {"type": "int", "min": 1, "max": 300},
          "body": {"type": "str", "max_length": 10000}
        },
        "delete_record": {
          "record_id": {"type": "str", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"}
        },
        "file_write": {
          "path": {"type": "str", "pattern": "^[a-zA-Z0-9/_.-]+$"}
        }
      },
      "rate_limit": {
        "delete_record": {
          "max_calls": 3,
          "window_seconds": 300
        }
      },
      "scope_creep": {
        "delete_record": {
          "protected_field": "record_id",
          "protected_tag": "protected_record_ids"
        }
      },
      "tag_tools": {
        "check_permissions": {
          "protected_field": "record_id",
          "protected_tag": "protected_record_ids"
        }
      }
    }
  }
}
